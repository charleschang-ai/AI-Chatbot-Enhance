<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ai_agent_source_wizard_form" model="ir.ui.view">
        <field name="name">ai.agent.source.wizard.form</field>
        <field name="model">ai.agent.source.wizard</field>
        <field name="arch" type="xml">
            <form string="Add Data Source">
                <sheet>
                    <group>
                        <field name="agent_id" invisible="1"/>

                        <field name="source_type" widget="radio" options="{'horizontal': true}"/>
                    </group>

                    <group invisible="source_type != 'binary'">
                        <field name="file_data" filename="file_name" widget="binary" string="Upload File"/>
                        <field name="file_name" invisible="1"/>
                    </group>

                    <group invisible="source_type != 'url'">
                        <field name="urls" placeholder="https://example.com&#10;https://docs.odoo.com" string="URLs"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm" string="Confirm" type="object" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>