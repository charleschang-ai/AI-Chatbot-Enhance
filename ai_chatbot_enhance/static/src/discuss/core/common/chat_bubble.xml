<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="mail.ChatBubble.core" t-inherit-mode="extension">
        <xpath expr="//button[hasclass('o-mail-ChatHub-bubbleBtn')]" position="after">
            <div class="ai-thread-badge-container">
                <div class="ai-thread-badge">
                    <span class="ai-badge-text" t-esc="thread.name">Ai Chat</span>
                    <span class="ai-badge-ring"></span>
                    <span class="ai-badge-corner-1"></span>
                    <span class="ai-badge-corner-2"></span>
                </div>
            </div>
        </xpath>
    </t>
</templates>