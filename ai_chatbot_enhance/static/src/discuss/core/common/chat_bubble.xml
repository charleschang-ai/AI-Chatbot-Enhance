            <div><span class="badge rounded-pill bg-info bg-gradient text-dark fw-bolder shadow-sm px-2 py-1"
                       style="font-size: 0.7rem; white-space: nowrap;" t-esc="thread.name">Ai Chat</span></div>
        </xpath>
    </t>
</templates>