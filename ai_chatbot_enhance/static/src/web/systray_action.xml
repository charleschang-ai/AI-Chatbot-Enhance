<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="ai.SystrayAction">
        <Dropdown position="'bottom-end'" menuClass="'ai-dropdown-menu shadow-lg border-0 rounded-4 p-2 mt-2'"
                  onOpened="() => this.onDropdownOpened()">

            <button class="btn d-flex justify-content-center align-items-center o_nav_entry rounded-circle p-2 mx-1"
                    style="transition: all 0.3s;" title="Ask AI">
                <img class="ai-systray-icon rounded-circle shadow-sm"
                     src="/ai_chatbot_enhance/static/description/icon.jpg" alt="AI"
                     style="width: 26px; height: 26px; object-fit: cover; border: 1px solid #eef2f6;"/>
            </button>

            <t t-set-slot="content">
                <div class="d-flex align-items-center px-3 py-2 mb-2 rounded-3"
                     style="background: linear-gradient(135deg, #f6f8fd 0%, #f1f5f9 100%); border-left: 4px solid #71639e;">
                    <i class="fa fa-magic text-primary me-2"/>
                    <span class="fw-bold text-dark" style="font-size: 14px; letter-spacing: 0.5px;">Agents</span>
                </div>

                <t t-foreach="state.agents" t-as="agent" t-key="agent.id">
                    <DropdownItem class="'px-3 py-2 rounded-3 mb-1 d-flex align-items-center ai-dropdown-item'"
                                  onSelected="() => this.onClickLaunchAIChat(agent)">

                        <div class="ai-avatar me-3 d-flex justify-content-center align-items-center rounded-circle bg-light text-primary shadow-sm"
                             style="width: 38px; height: 38px; font-size: 18px; overflow: hidden;">

                            <t t-if="agent.image_128">
                                <img t-attf-src="/web/image/ai.agent/{{agent.id}}/image_128"
                                     alt="Agent Avatar"
                                     style="width: 100%; height: 100%; object-fit: cover;"/>
                            </t>
                            <t t-else="">
                                <i class="fa fa-robot"/>
                            </t>
                        </div>

                        <div class="d-flex flex-column justify-content-center">
                            <span class="fw-bold text-dark mb-0" style="font-size: 14px;" t-esc="agent.name"/>
                            <span class="text-muted" style="font-size: 11px; margin-top: 2px;">
                                <i class="fa fa-microchip me-1" style="color: #10b981;"/>
                                <span style="color: #3b82f6; font-weight: 500;" t-esc="agent.llm_model"/>
                            </span>
                        </div>

                    </DropdownItem>
                </t>

                <t t-if="state.agents.length === 0">
                    <div class="px-4 py-5 text-center text-muted d-flex flex-column align-items-center">
                        <i class="fa fa-inbox fa-3x mb-3 opacity-25"/>
                        <span style="font-size: 13px; font-weight: 500;">No Agent</span>
                    </div>
                </t>
            </t>

        </Dropdown>
    </t>
</templates>